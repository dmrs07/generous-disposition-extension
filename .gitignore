# OS and editor noise
**/.DS_Store
**/Thumbs.db
**/*.swp
**/*~

# Keep shared VS Code workspace config, ignore the rest
**/.vscode/*
!**/.vscode/launch.json
!**/.vscode/tasks.json
!**/.vscode/settings.json
!**/.vscode/extensions.json

# Environment and logs
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Node and frontend tooling
**/node_modules/
**/.npm/
**/.pnpm-store/
**/.yarn/
**/.parcel-cache/
**/.turbo/
**/.vite/
**/coverage/
**/.nyc_output/
**/.eslintcache
**/*.tsbuildinfo
**/*.tgz

# VS Code extension build artifacts
/generous-disposition-extension/dist/
/generous-disposition-extension/out/
/generous-disposition-extension/.vscode-test/
/generous-disposition-extension/*.vsix

# Site deployment/build artifacts
/generous-disposition-site/dist/
/generous-disposition-site/.vercel/

# Local archives
/generous-disposition-site.tar.gz
