{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^(INTENT|WHY|FOR|CONTEXT|CONSTRAINTS|EXAMPLE|ASSUMPTIONS|DECOMPOSE)\\s*:",
      "end": "^(INTENT|WHY|FOR|CONTEXT|CONSTRAINTS|EXAMPLE|ASSUMPTIONS|DECOMPOSE)\\s*:|^---"
    }
  },
  "wordPattern": "[A-Za-z0-9_\\-]+"
}
